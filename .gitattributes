# Normalize all text files to LF in the repo, regardless of platform.
# Avoids "LF will be replaced by CRLF" warnings on Windows when core.autocrlf=true.
* text=auto eol=lf

# Binary files — leave bytes untouched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.pdb binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
